# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get these from your Stripe dashboard (Developers → API Keys / Webhooks)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: if you have an existing recurring Price in Stripe, set its ID here.
# If left blank, a dynamic 42 EUR/month price is created per session.
# STRIPE_PRICE_ID=price_...

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Just Eat / Liferando DaaS ─────────────────────────────────────────────────
# Credentials provided by Just Eat after DaaS partner onboarding
JUST_EAT_CLIENT_ID=your_client_id
JUST_EAT_CLIENT_SECRET=your_client_secret

# API endpoints — defaults below work for the UK/international DaaS API.
# Check your onboarding docs for region-specific URLs (e.g. Lieferando DE).
JUST_EAT_API_BASE_URL=https://uk.api.just-eat.io
JUST_EAT_AUTH_URL=https://auth.just-eat.io/oauth/token

# Webhook signature secret provided by Just Eat for verifying incoming events
# JUST_EAT_WEBHOOK_SECRET=your_webhook_secret

# ─── Pickup location (blackbird office) ────────────────────────────────────────
# Where the Just Eat courier picks up the order from
JUST_EAT_PICKUP_NAME=blackbird
JUST_EAT_PICKUP_STREET=Sebnitzer Str. 35
JUST_EAT_PICKUP_CITY=Dresden
JUST_EAT_PICKUP_POSTCODE=01099
JUST_EAT_PICKUP_COUNTRY=DE
JUST_EAT_PICKUP_PHONE=+49...

# ─── Site ──────────────────────────────────────────────────────────────────────
# Your production URL (used for Stripe success/cancel redirect URLs)
SITE_URL=https://blackbird.com

# ─── Legacy (no longer used — buy button now goes through /api/create-checkout) ─
# VITE_STRIPE_PAYMENT_LINK=
# VITE_STRIPE_SUBSCRIPTION_LINK=
