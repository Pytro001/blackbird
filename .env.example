# Supabase (Project Settings → API → Project URL + anon public key)
VITE_SUPABASE_URL=https://gvtigdnphgotoqpwhfdt.supabase.co
VITE_SUPABASE_ANON_KEY=

# Stripe Checkout (set in Vercel → Environment Variables, not prefixed with VITE_)
